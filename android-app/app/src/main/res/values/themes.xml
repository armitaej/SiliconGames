<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme -->
    <style name="Theme.SiliconGames" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryVariant">@color/neon_pink</item>
        <item name="colorOnPrimary">@color/black</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.SiliconGames.Splash" parent="Theme.SiliconGames">
        <item name="android:windowSplashScreenBackground">@color/splash_bg</item>
    </style>
</resources>
